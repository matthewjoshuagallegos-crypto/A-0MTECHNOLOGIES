{
  "name": "a0m-technologies",
  "private": true,
  "description": "com.a#0m.package.app // A#0M Authority Console - FCC Compliant 512-bit Secure Gaming Environment",
  "version": "1.0.0",
  "author": "Matthew Joshua Gallegos (Author, Creator, Engineer) & Google LLC",
  "license": "A#0M Technologies TM",
  "type": "module",
  "bin": {
    "a0m": "./cli.js"
  },
  "scripts": {
    "start": "node dist/server.cjs",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --target=node18 --outfile=dist/server.cjs --external:express --external:vite --external:stripe --external:ws --external:node-cron --external:better-sqlite3",
    "postbuild": "echo '[!] COMPILING com.a#0m.package.app' && cp dist/index.html dist/com.a#0m.package.app.html && echo '[+] INSTALLABLE TARGETS GENERATED IN dist/'",
    "publish": "npm run build && echo 'Applet published successfully'",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@tailwindcss/vite": "^4.1.14",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.5",
    "express": "^4.22.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.184.0",
    "vite": "^6.2.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
